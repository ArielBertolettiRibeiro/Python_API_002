# ============================================================
# TEMPLATE DE CONFIGURAÇÃO
# Copie este arquivo para .env e preencha com seus valores.
# Este arquivo PODE ir para o git (sem valores reais).
# ============================================================

# ================================
# APLICAÇÃO
# ================================
APP_NAME=Gestão de Estoque
APP_ENV=development
DEBUG=true
API_VERSION=v1

# ================================
# SERVIDOR
# ================================
HOST=0.0.0.0
PORT=8000

# ================================
# BANCO DE DADOS
# ================================
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/python_api_002_dev

# ================================
# SEGURANÇA / JWT
# ================================
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ================================
# CORS
# ================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
